---
import Layout from "../layouts/layout.astro"

interface WordPressPage {
  id: number
  status: string
  link: string
  title: { rendered: string }
  content: { rendered: string }
  menu_order?: number
}

export async function getStaticPaths() {
  const response = await fetch("https://upalorena.com.br/wp/wp-json/wp/v2/pages?per_page=100&_fields=id,status,link,title,menu_order,content&orderby=menu_order&order=asc")

  if (!response.ok) {
    return []
  }

  const data = (await response.json()) as WordPressPage[]

  const pages = data.filter((page) => page.status === "publish")

  return pages.map((page) => {
    const url = new URL(page.link)
    const normalizedPath = url.pathname.replace(/^\/wp\//, "/").replace(/\/+$/, "")
    const segments = normalizedPath.split("/").filter(Boolean)
    const slug = segments[segments.length - 1] || ""

    return {
      params: { slug },
      props: { page },
    }
  })
}

interface Props {
  page: WordPressPage
}

const { page } = Astro.props as Props
---

<Layout title={`${page.title.rendered} | UPA - União Protetora dos Animais`}>
  <section class="page">
    <h1>{page.title.rendered}</h1>
    <article class="page-content" set:html={page.content.rendered} />
  </section>
</Layout>

<style>
  .page {
    max-width: var(--max-width);
    padding: 60px 15px 0;
    margin: 0 auto;
  }

  .page-content {
    margin-top: 24px;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .page-content a {
    color: var(--color-prim);
    text-decoration: underline;
  }
</style>

