---
import Container from "./grid/container.astro"

export interface SliderItem {
  slider_image: {
    url: string
    alt: string
    width?: number
    height?: number
  }
  slider_title: string
  slider_about: string
  slider_link?: string // Campo opcional para link, caso exista no futuro ou seja adaptado
}

interface Props {
  slides: SliderItem[]
  interval?: number // Tempo em ms, default 5000
}

const { slides, interval = 5000 } = Astro.props

const hasSlides = slides && slides.length > 0
---

{
  hasSlides && (
    <section
      class="carousel"
      aria-label="Destaques"
      data-interval={interval}
    >
      <div class="carousel-inner">
        {slides.map((slide, slideIndex) => (
          <div
            class={`carousel-item ${slideIndex === 0 ? "active" : ""}`}
            aria-hidden={slideIndex !== 0}
          >
            <div class="carousel-image">
               <img
                src={slide.slider_image.url}
                alt={slide.slider_image.alt || slide.slider_title}
                loading={slideIndex === 0 ? "eager" : "lazy"}
                width={slide.slider_image.width}
                height={slide.slider_image.height}
              />
            </div>
            <div class="carousel-caption">
              <Container>
                <div class="caption-content">
                  <h2 class="title">{slide.slider_title}</h2>
                  <p class="description">{slide.slider_about}</p>
                  {slide.slider_link && (
                    <a href={slide.slider_link} class="btn">Saiba mais</a>
                  )}

                  <div class="carousel-indicators">
                    {slides.map((_, indicatorIndex) => (
                      <button
                        type="button"
                        data-slide-to={indicatorIndex}
                        class={indicatorIndex === slideIndex ? "active" : ""}
                        aria-current={indicatorIndex === slideIndex ? "true" : "false"}
                        aria-label={`Ir para o slide ${indicatorIndex + 1}`}
                      />
                    ))}
                  </div>
                </div>
              </Container>
            </div>
          </div>
        ))}
      </div>

      {/* {slides.length > 1 && (
        <>
          <button class="carousel-control prev" aria-label="Slide anterior">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <button class="carousel-control next" aria-label="Próximo slide">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </>
      )} */}
    </section>
  )
}

<style>
  .carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: var(--color-back-dark);
  }

  .carousel-inner {
    position: relative;
    width: 100%;
    min-height: 600px;
    display: grid;
    grid-template-areas: "slide";
  }

  .carousel-item {
    grid-area: slide;
    position: relative;
    opacity: 0;
    transition: opacity 0.6s ease-in-out;
    z-index: 1;
    display: flex;
    align-items: end;
    justify-content: center;
    width: 100%;
  }

  .carousel-item.active {
    opacity: 1;
    z-index: 2;
  }

  .carousel-image {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  .carousel-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Overlay escuro para melhorar leitura do texto */
  .carousel-image::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .carousel-caption {
    position: relative;
    z-index: 3;
    width: 100%;
    padding: 30px 0;
    pointer-events: none; /* Permite clicar através da caption se necessário, mas o botão tem pointer-events: auto */
  }

  .caption-content {
    max-width: 450px;
    pointer-events: auto;
  }

  .title {
    font-family: 'Amatic SC', sans-serif;
    font-size: 4rem;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: var(--color-prim);
  }

  .description {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  /* Controls */
  .carousel-control {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    background: rgba(0,0,0,0.3);
    border: none;
    color: #fff;
    padding: 10px;
    cursor: pointer;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    width: 48px;
    height: 48px;
  }

  .carousel-control:hover {
    background: rgba(0,0,0,0.6);
  }

  .prev { left: 20px; }
  .next { right: 20px; }

  /* Indicators */
  .carousel-indicators {
    display: flex;
    gap: 10px;
    margin: 30px 0 0 0;
  }

  .carousel-indicators button {
    width: 12px;
    height: 12px;
    padding: 0;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: var(--color-back);
    border: 1px solid var(--color-prim);
  }

  .carousel-indicators button.active {
    background: var(--color-prim);
    transform: scale(1.2);
  }

  @media (max-width: 768px) {
    .carousel-inner {
      min-height: 500px; /* Mais altura no mobile para caber texto */
    }

    .title {
      font-size: 3rem;
    }

    .description {
      font-size: 0.75rem;
    }

    .carousel-control {
      width: 36px;
      height: 36px;
    }

    .prev { left: 10px; }
    .next { right: 10px; }
  }
</style>

<script>
  class Carousel {
    element: HTMLElement;
    items: NodeListOf<Element>;
    prevBtn: HTMLElement | null;
    nextBtn: HTMLElement | null;
    intervalTime: number;
    currentIndex: number;
    timer: number | null;
    isPlaying: boolean;

    constructor(element: HTMLElement) {
      this.element = element;
      this.items = element.querySelectorAll('.carousel-item');
      this.prevBtn = element.querySelector('.prev');
      this.nextBtn = element.querySelector('.next');
      this.intervalTime = Number(element.dataset.interval) || 5000;
      this.currentIndex = 0;
      this.timer = null;
      this.isPlaying = true;

      this.init();
    }

    init() {
      if (this.items.length < 2) return;

      this.startAutoplay();
      this.addEventListeners();
    }

    showSlide(index: number) {
      // Normalize index
      if (index < 0) {
        index = this.items.length - 1;
      } else if (index >= this.items.length) {
        index = 0;
      }

      // Update state
      this.items[this.currentIndex].classList.remove('active');
      this.items[this.currentIndex].setAttribute('aria-hidden', 'true');

      this.currentIndex = index;

      this.items[this.currentIndex].classList.add('active');
      this.items[this.currentIndex].setAttribute('aria-hidden', 'false');
    }

    next() {
      this.showSlide(this.currentIndex + 1);
    }

    prev() {
      this.showSlide(this.currentIndex - 1);
    }

    startAutoplay() {
      if (this.timer) clearInterval(this.timer);
      this.timer = window.setInterval(() => this.next(), this.intervalTime);
      this.isPlaying = true;
    }

    stopAutoplay() {
      if (this.timer) {
        clearInterval(this.timer);
        this.timer = null;
      }
      this.isPlaying = false;
    }

    addEventListeners() {
      // Pause on hover
      this.element.addEventListener('mouseenter', () => this.stopAutoplay());
      this.element.addEventListener('mouseleave', () => this.startAutoplay());

      // Controls
      this.prevBtn?.addEventListener('click', () => {
        this.prev();
        this.stopAutoplay();
      });

      this.nextBtn?.addEventListener('click', () => {
        this.next();
        this.stopAutoplay();
      });

      // Indicators click handling
      // Select all indicators inside the carousel
      const allIndicators = this.element.querySelectorAll('.carousel-indicators button');
      allIndicators.forEach((indicator) => {
        indicator.addEventListener('click', (e) => {
          // Type assertion for HTMLElement to access dataset
          const target = e.currentTarget as HTMLElement;
          const targetIndex = Number(target.dataset.slideTo);
          if (!isNaN(targetIndex)) {
            this.showSlide(targetIndex);
            this.stopAutoplay();
          }
        });
      });

      // Keyboard navigation
      this.element.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') {
          this.prev();
        } else if (e.key === 'ArrowRight') {
          this.next();
        }
      });
    }
  }

  // Initialize all carousels on the page
  document.addEventListener('astro:page-load', () => {
    const carousels = document.querySelectorAll('.carousel');
    carousels.forEach(el => new Carousel(el as HTMLElement));
  });

  // Fallback for non-ViewTransitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      const carousels = document.querySelectorAll('.carousel');
      carousels.forEach(el => new Carousel(el as HTMLElement));
    });
  } else {
    // Already loaded
    const carousels = document.querySelectorAll('.carousel');
    carousels.forEach(el => new Carousel(el as HTMLElement));
  }
</script>
